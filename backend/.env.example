# Agent Knowledge - 后端环境变量模板
# 复制此文件为 .env 或在启动命令中传入环境变量

# 数据库配置
# dev/test 可使用内存 H2；教学演示或真实联调建议使用 local profile + MySQL。
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=10001
# DB_URL=jdbc:mysql://localhost:3306/agent_knowledge?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true
# DB_USERNAME=root
# DB_PASSWORD=your_password_here
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_DIALECT=org.hibernate.dialect.MySQL8Dialect

# 时间策略：默认 UTC；如需本地展示时区，可设为 Asia/Shanghai
APP_TIME_ZONE=UTC

# 服务间 HTTP 调用默认配置
APP_REMOTE_CALLER_ID=agent-knowledge
REMOTE_HTTP_CONNECT_TIMEOUT_MS=3000
REMOTE_HTTP_READ_TIMEOUT_MS=300000
REMOTE_HTTP_DEFAULT_RETRY_COUNT=0
REMOTE_HTTP_DEFAULT_RETRY_INTERVAL_MS=1000
REMOTE_HTTP_POLICY_ENABLED=false
# REMOTE_HTTP_POLICY_BLOCKED_SERVICE_IDS=
# REMOTE_HTTP_POLICY_ALLOWED_CALLER_IDS=

# RAG 服务配置
UPLOAD_BASE_DIR=./uploads
DOC_PARSER_URL=http://localhost:9001
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Druid 监控后台
DRUID_USERNAME=admin
DRUID_PASSWORD=your_druid_password

# Redis（如启用）
# FEATURE_REDIS_ENABLED=false
# FEATURE_CACHE_TYPE=memory
# FEATURE_DISTRIBUTED_LOCK_PROVIDER=local
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0
# REDIS_TIMEOUT=5000

# Kafka（如启用）
# FEATURE_KAFKA_ENABLED=false

# MinIO（如启用）
# FEATURE_MINIO_ENABLED=false
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=your_access_key
# MINIO_SECRET_KEY=your_secret_key
# MINIO_BUCKET=default

# OSS（如启用）
# FEATURE_OSS_ENABLED=false
# OSS_ENDPOINT=
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=

# 生产日志与监控（按需启用）
# APP_ENABLE_JSON_LOG=true
# APP_LOG_ASYNC_QUEUE_SIZE=4096
# FEATURE_MONITORING_PERFORMANCE_ENABLED=false
# FEATURE_MONITORING_METRICS_ENABLED=true
